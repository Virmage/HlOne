# ═══════════════════════════════════════════════════════════════════
# CLOUD DEPLOYMENT ENV VARS
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Neon free tier) ────────────────────────────────────
# Sign up: https://neon.tech → Create project → Copy connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hl_copy?sslmode=require

# ─── Redis (Upstash free tier) ────────────────────────────────────
# Sign up: https://upstash.com → Create Redis database → Copy URL
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# ─── API Server (Railway) ────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://your-app.vercel.app

# ─── Frontend (Vercel env vars) ──────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
# Get WalletConnect project ID: https://cloud.walletconnect.com

# ─── Worker ──────────────────────────────────────────────────────
HEALTH_PORT=3002

# ─── Builder Fee (Revenue) ───────────────────────────────────────
# Your wallet address that receives builder fees
BUILDER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE
# Fee in tenths of basis points: 5 = 0.5bps = 0.05%
BUILDER_FEE=5
